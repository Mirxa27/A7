# Agent7 Intelligence Interface - Environment Configuration

# Database (Prisma Accelerate)
# Get your connection string from: https://console.prisma.io
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_API_KEY_HERE"

# AI API Keys (Add your keys here)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=""
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=""

# Server Configuration
PORT=3000
NODE_ENV=development

# Security (Change in production)
SESSION_SECRET="change-this-to-a-random-string-in-production"

# Features
ENABLE_TTS=true
ENABLE_PREMIUM_TOOLS=true
